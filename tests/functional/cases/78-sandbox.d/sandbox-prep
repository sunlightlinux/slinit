type = scripted
depends-on: system-init
# Pre-create host directory bind-mounted by read-write-paths.
# The source must exist before the runner does the bind; the script
# inside the sandbox can't help — its mkdir runs in the namespace
# after the mount layout is already set.
#
# Path is under /run (not /var/tmp) because the sandbox-svc enables
# private-tmp, which replaces /var/tmp with a fresh tmpfs and would
# hide anything mkdir'd here.
command = /bin/sh -c "mkdir -p /run/sandbox-rw"
stop-command = /bin/true
