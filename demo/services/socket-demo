# socket-demo — socket activation (systemd-style LISTEN_FDS)
# Demonstrates socket-listen with immediate activation.
# slinit opens the socket and passes it as fd 3 via LISTEN_FDS=1.
# Try: echo hello | nc -U /run/socket-demo.sock
# Try: slinitctl catlog socket-demo
type = process
command = /bin/sh -c "echo '[socket-demo] started with LISTEN_FDS=$LISTEN_FDS'; while true; do sleep 30; done"
socket-listen = /run/socket-demo.sock
socket-permissions = 0666
socket-activation = immediate
log-type = buffer
log-buffer-size = 4096
restart = on-failure
depends-on: system-init
