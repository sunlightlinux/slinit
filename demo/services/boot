# boot -- system boot milestone
# Default boot target. Brings up the base system (system-init), every
# demo workload (all-services), and finally the interactive console
# shell (tty). tty is ordered "after: all-services" so the login prompt
# is not interleaved with the service-start list.
type = internal
depends-on: system-init
depends-on: all-services
depends-on: tty
# trigger-test is a `triggered` service: it stays in STARTING until
# `slinitctl trigger trigger-test`. Referenced here (not in all-services)
# so it is loaded/visible for the demo without blocking the login prompt.
waits-for: trigger-test
# hello-initd is auto-detected from /etc/init.d at runtime;
# slinit-check (offline) doesn't scan init.d, so it's not listed here.
# Start it manually in the demo with: rc-service hello-initd start
