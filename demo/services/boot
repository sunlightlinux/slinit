# boot -- system boot milestone
# Default boot target. Depends on essential services,
# waits for optional services.
type = internal
depends-on: system-init
depends-on: tty
waits-for: hello
waits-for: ticker
waits-for: dep-chain
waits-for: trigger-test
waits-for: cpu-pinned
waits-for: hello-logged
waits-for: logger
waits-for: env-demo
waits-for: graceful-stop
