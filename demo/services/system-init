# system-init -- mount essential filesystems
# Scripted service: runs command once, exits 0 = STARTED.
# Does NOT mount /run (rootfs is already tmpfs from initramfs).
type = scripted
command = /bin/sh -c "mount -t proc proc /proc 2>/dev/null; mount -t sysfs sysfs /sys 2>/dev/null; mount -t devtmpfs devtmpfs /dev 2>/dev/null; mkdir -p /dev/pts && mount -t devpts devpts /dev/pts 2>/dev/null; echo 'system-init: filesystems mounted'"
stop-command = /bin/sh -c "echo 'system-init: stop (no-op)'"
stop-timeout = 5
